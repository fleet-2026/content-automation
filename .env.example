# ═══════════════════════════════════════════════════════════════
# Creator OS — Environment Variables
# Copy this to `.env.local` and fill in. Never commit `.env.local`.
# ═══════════════════════════════════════════════════════════════

# ─── APP ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
# Generate: openssl rand -base64 32
AUTH_SECRET=

# Single-user gate. Only this email can sign in.
ADMIN_EMAIL=

# ─── DATABASE (Postgres + pgvector) ──────────────────────────
# Recommended: Neon — neon.tech (enable pgvector in console)
# Or: Supabase, Railway, local Postgres
DATABASE_URL=postgresql://user:password@host:5432/creator_os?sslmode=require

# ─── ENCRYPTION (for stored OAuth tokens) ────────────────────
# Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# ─── AI ──────────────────────────────────────────────────────
# Claude — for script writing, hook analysis, RAG Q&A
ANTHROPIC_API_KEY=

# OpenAI — for embeddings (text-embedding-3-large)
OPENAI_API_KEY=

# Groq — for fast/cheap Whisper transcription
GROQ_API_KEY=

# ─── STORAGE (Cloudflare R2 — S3-compatible) ─────────────────
# Used for storing competitor video/audio for transcription
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=creator-os
R2_PUBLIC_URL=

# ─── INNGEST (durable workers) ───────────────────────────────
# Get from inngest.com (free dev tier)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── INSTAGRAM (Meta Graph API) ──────────────────────────────
# Create app at developers.facebook.com/apps
# Required: instagram_basic, instagram_content_publish, pages_show_list
META_APP_ID=
META_APP_SECRET=
# Long-lived user token (60 days) for read-only analytics fallback
META_USER_TOKEN=

# ─── TIKTOK ──────────────────────────────────────────────────
# developers.tiktok.com — request Display API + Content Posting API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ─── YOUTUBE (Google Cloud OAuth) ────────────────────────────
# console.cloud.google.com → enable YouTube Data API v3 + YouTube Analytics API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── APIFY (competitor scraping) ─────────────────────────────
# apify.com — pay-per-result actors for IG / TikTok / YouTube
APIFY_TOKEN=

# ─── TAVILY (niche news search) ──────────────────────────────
TAVILY_API_KEY=
