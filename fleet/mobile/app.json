{
  "expo": {
    "name": "Fleet",
    "slug": "fleet-mobile",
    "scheme": "fleet",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "FleetOS uses your location to set your pickup point and track trips."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "FleetOS uses your location to set your pickup point."
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"],
      "config": {
        "googleMaps": { "apiKey": "REPLACE_WITH_ANDROID_GOOGLE_MAPS_KEY" }
      }
    },
    "extra": {
      "apiBaseUrl": "http://localhost:3001"
    }
  }
}
