# Local dev uses SQLite — zero external services needed.
DATABASE_URL="file:./dev.db"

# Secret used to sign session JWTs (web cookie + mobile bearer). Use a long
# random string in production: `openssl rand -base64 32`
AUTH_SECRET="dev-insecure-secret-change-me"

# Shared secret for the scheduled expiry-reminder endpoint. The scheduler must
# send it as the `x-cron-secret` header. Leave unset to disable the check (dev).
CRON_SECRET=""

# For production, switch prisma/schema.prisma `provider` to "postgresql" and set:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/fleet?sslmode=require"
